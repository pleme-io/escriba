{
  description = "escriba — Rust + tatara-lisp editor, built on the pleme-io GPU stack";

  inputs = {
    nixpkgs.url = "github:nixos/nixpkgs?ref=nixos-unstable";
    flake-utils.url = "github:numtide/flake-utils";

    # Pleme-io siblings — Cargo.toml has ../<sibling> path deps; the flake
    # composes them into a hermetic workspace tree. Local dev still uses
    # the in-tree paths; the flake just shadows them during nix builds.
    tatara   = { url = "git+ssh://git@github.com/pleme-io/tatara"; flake = false; };
    shikumi  = { url = "github:pleme-io/shikumi";                  flake = false; };
    garasu   = { url = "github:pleme-io/garasu";                   flake = false; };
    madori   = { url = "github:pleme-io/madori";                   flake = false; };
    awase    = { url = "github:pleme-io/awase";                    flake = false; };
    hayai    = { url = "github:pleme-io/hayai";                    flake = false; };
    irodori  = { url = "github:pleme-io/irodori";                  flake = false; };
    mojiban  = { url = "github:pleme-io/mojiban";                  flake = false; };

    substrate = { url = "github:pleme-io/substrate"; inputs.nixpkgs.follows = "nixpkgs"; };
  };

  outputs = inputs @ { self, nixpkgs, flake-utils, substrate, ... }:
    let
      lib = nixpkgs.lib;

      renderTheme = s:
        ''(deftheme :preset "${s.theme}")'';

      renderOptions = s: lib.concatStringsSep "\n" (lib.filter (x: x != "") [
        ''(defoption :name "tabstop"        :value "${toString s.tabWidth}")''
        ''(defoption :name "shiftwidth"     :value "${toString s.tabWidth}")''
        (if s.lineNumbers
         then ''(defoption :name "number"         :value "true")''
         else ''(defoption :name "number"         :value "false")'')
        (if s.relativeNumbers
         then ''(defoption :name "relativenumber" :value "true")''
         else ''(defoption :name "relativenumber" :value "false")'')
        (if s.wrap
         then ''(defoption :name "wrap"           :value "true")''
         else ''(defoption :name "wrap"           :value "false")'')
        (if s.cursorLine
         then ''(defoption :name "cursorline"     :value "true")''
         else ''(defoption :name "cursorline"     :value "false")'')
      ]);

      renderExtraKeybinds = binds:
        lib.concatMapStringsSep "\n" (b:
          ''(defkeybind :mode "${b.mode}" :key "${b.key}" :action "${b.action}"${
            lib.optionalString (b ? description && b.description != "") ''
 :description "${b.description}"''})''
        ) binds;

      renderRc = cfg: ''
        ;; ~/.config/escriba/rc.lisp — generated by home-manager.
        ;; Edits here get overwritten. Change HM `programs.escriba.*` to
        ;; regenerate, or drop extra forms into `extraConfig`.
        ;;
        ;; Loads *after* the binary's bundled blnvim-parity defaults, so
        ;; declarations here override that baseline.

        ${renderTheme cfg.settings}

        ${renderOptions cfg.settings}

        ${lib.optionalString (cfg.extraKeybinds != []) (renderExtraKeybinds cfg.extraKeybinds)}

        ${cfg.extraConfig}
      '';

      trio = (import "${substrate}/lib/module-trio.nix" { inherit lib; }).mkModuleTrio {
        name = "escriba";
        description = "escriba — Rust + tatara-lisp editor (16 def-forms, blnvim-parity defaults)";
        hmNamespace = "programs";
        packageAttr = "escriba";
        binaryName = "escriba";

        extraHmOptions = {
          settings = lib.mkOption {
            default = {};
            description = ''
              Structured editor settings. Rendered to tatara-lisp
              `(deftheme …)` and `(defoption …)` forms in the
              generated rc file.
            '';
            type = lib.types.submodule {
              options = {
                theme = lib.mkOption {
                  type = lib.types.enum [ "nord" "gruvbox-dark" "tokyo-night" "catppuccin-mocha" ];
                  default = "nord";
                  description = "Color preset — escriba-lisp `deftheme`.";
                };
                tabWidth = lib.mkOption {
                  type = lib.types.ints.between 1 16;
                  default = 2;
                  description = "Display width of a tab — `defoption :tabstop` / `:shiftwidth`.";
                };
                lineNumbers = lib.mkOption {
                  type = lib.types.bool;
                  default = true;
                  description = "Show the line-number gutter — `defoption :number`.";
                };
                relativeNumbers = lib.mkOption {
                  type = lib.types.bool;
                  default = true;
                  description = "Show relative line numbers — `defoption :relativenumber`.";
                };
                wrap = lib.mkOption {
                  type = lib.types.bool;
                  default = false;
                  description = "Soft-wrap long lines — `defoption :wrap`.";
                };
                cursorLine = lib.mkOption {
                  type = lib.types.bool;
                  default = true;
                  description = "Highlight the cursor line — `defoption :cursorline`.";
                };
              };
            };
          };

          extraKeybinds = lib.mkOption {
            type = lib.types.listOf (lib.types.submodule {
              options = {
                mode = lib.mkOption {
                  type = lib.types.enum [ "normal" "insert" "visual" "visual-line" "command" ];
                  default = "normal";
                };
                key = lib.mkOption { type = lib.types.str; };
                action = lib.mkOption { type = lib.types.str; };
                description = lib.mkOption { type = lib.types.str; default = ""; };
              };
            });
            default = [];
            description = ''
              Additional keybindings rendered as `(defkeybind …)` forms.
              These override bundled-default bindings on collision.
            '';
          };

          extraConfig = lib.mkOption {
            type = lib.types.lines;
            default = "";
            description = ''
              Additional tatara-lisp appended verbatim to the generated
              `~/.config/escriba/rc.lisp`. Use this for def-forms the HM
              surface doesn't model directly (`defplugin`, `defhighlight`,
              `defhook`, `defsnippet`, etc.).
            '';
          };

          noDefaults = lib.mkOption {
            type = lib.types.bool;
            default = false;
            description = ''
              Pass `--no-defaults` by aliasing `escriba` to skip the
              bundled blnvim-parity rc. Only the generated rc + extras
              apply. Most users should leave this off.
            '';
          };
        };

        extraHmConfig = cfg: {
          home.file.".config/escriba/rc.lisp".text = renderRc cfg;

          # Session env — binary already falls back to ~/.config/escriba/rc.lisp
          # but setting ESCRIBARC makes the resolution explicit + survives
          # users who XDG_CONFIG_HOME elsewhere. Use $HOME (shell-expanded)
          # since extraHmConfig has no access to config.home.homeDirectory.
          home.sessionVariables = {
            ESCRIBARC = "$HOME/.config/escriba/rc.lisp";
          } // lib.optionalAttrs cfg.noDefaults {
            ESCRIBA_NO_DEFAULTS = "1";
          };
        };
      };
    in
    flake-utils.lib.eachDefaultSystem (system:
      let
        pkgs = import nixpkgs { inherit system; };

        cleanEscriba = pkgs.lib.cleanSourceWith {
          src = ./.;
          filter = path: type:
            let rel = pkgs.lib.removePrefix (toString ./.) (toString path);
            in !(builtins.match "^/target(/.*)?$" rel != null
                 || builtins.match "^/result.*$" rel != null
                 || builtins.match ".*/\\.direnv(/.*)?$" rel != null);
        };

        # Compose a workspace tree that mirrors the Cargo.toml layout:
        #   escriba/    ← this repo
        #   tatara/     shikumi/    garasu/    madori/    ← path siblings
        #   awase/      hayai/      irodori/   mojiban/
        composedSrc = pkgs.runCommand "escriba-composed-src" {} ''
          mkdir -p $out/escriba
          cp -r ${cleanEscriba}/. $out/escriba/
          chmod -R +w $out/escriba
          for sib in tatara shikumi garasu madori awase hayai irodori mojiban; do
            case "$sib" in
              tatara)  src="${inputs.tatara}";;
              shikumi) src="${inputs.shikumi}";;
              garasu)  src="${inputs.garasu}";;
              madori)  src="${inputs.madori}";;
              awase)   src="${inputs.awase}";;
              hayai)   src="${inputs.hayai}";;
              irodori) src="${inputs.irodori}";;
              mojiban) src="${inputs.mojiban}";;
            esac
            cp -r "$src" "$out/$sib"
            chmod -R +w "$out/$sib"
          done
        '';

        mkBin = { pname, package }: pkgs.rustPlatform.buildRustPackage {
          inherit pname;
          version = "0.1.0";
          src = composedSrc;
          sourceRoot = "escriba-composed-src/escriba";
          cargoLock = {
            lockFile = ./Cargo.lock;
            # Allow Nix to fetch git-sourced deps dynamically — path
            # deps are preferred, but transitive git sources (egaku,
            # garasu via madori, shikumi) still appear in the lockfile
            # and need fetching at build time.
            allowBuiltinFetchGit = true;
          };
          cargoBuildFlags = [ "-p" package ];
          cargoTestFlags  = [ "-p" package ];
          doCheck = false;
          buildInputs = with pkgs; (
            if stdenv.isDarwin
            then [ fontconfig freetype ]
            else [
              libxkbcommon wayland vulkan-loader
              libGL mesa xorg.libX11 xorg.libXcursor xorg.libXi xorg.libXrandr
              fontconfig freetype
            ]
          );
          nativeBuildInputs = with pkgs; [ pkg-config ];
        };

        escriba = mkBin { pname = "escriba"; package = "escriba"; };
      in {
        packages = {
          inherit escriba;
          default = escriba;
        };
        apps.default = { type = "app"; program = "${escriba}/bin/escriba"; };
        devShells.default = pkgs.mkShell {
          name = "escriba-dev";
          packages = with pkgs; [
            rustc cargo rustfmt clippy rust-analyzer
            pkg-config libxkbcommon wayland vulkan-loader
            libGL fontconfig freetype
            git jq yq-go
          ];
        };
        checks = {
          cargo-fmt = pkgs.runCommand "fmt" {
            src = cleanEscriba;
            nativeBuildInputs = [ pkgs.rustfmt pkgs.cargo ];
          } "cd $src && cargo fmt --all -- --check && touch $out";
        };
      }) // {
        overlays.default = final: prev: {
          escriba = self.packages.${final.system}.escriba;
        };
        homeManagerModules.default = trio.homeManagerModule;
        nixosModules.default = trio.nixosModule;
        darwinModules.default = trio.darwinModule;
      };
}
